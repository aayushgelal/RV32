// === TEST 1: Independent instructions (no hazards) ===
00500093  // 0x00: addi x1, x0, 5
00A00113  // 0x04: addi x2, x0, 10
00F00193  // 0x08: addi x3, x0, 15
01400213  // 0x0C: addi x4, x0, 20

// === TEST 2: Dependent instruction with 3 NOPs ===
// x5 depends on x1, which was written 7+ instructions ago — safe
00108293  // 0x10: addi x5, x1, 1    (x5 = x1 + 1 = 6)

// === TEST 3: Store then Load (with NOPs for safety) ===
// Store x1 (5) to mem[0]
00102023  // 0x14: sw   x1, 0(x0)    (mem[0] = 5)
00000013  // 0x18: nop
00000013  // 0x1C: nop
00000013  // 0x20: nop
// Load from mem[0] into x6
00002303  // 0x24: lw   x6, 0(x0)    (x6 = mem[0] = 5)

// === TEST 4: LUI ===
DEADB3B7  // 0x28: lui  x7, 0xDEADB  (x7 = 0xDEADB000)

// === TEST 5: AUIPC ===
00001417  // 0x2C: auipc x8, 1       (x8 = 0x2C + 0x1000 = 0x102C)

// === TEST 6: JAL (jump forward over 2 instructions) ===
00000013  // 0x30: nop (let previous writes finish)
00000013  // 0x34: nop
00000013  // 0x38: nop
00C004EF  // 0x3C: jal  x9, +12      (x9 = 0x40, jump to 0x48)
00100513  // 0x40: addi x10, x0, 1   (SKIPPED by flush)
00100513  // 0x44: addi x10, x0, 1   (SKIPPED by flush)
00000513  // 0x48: addi x10, x0, 0   (x10 = 0, JAL lands here)
