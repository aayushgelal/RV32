00500093  // 0x00: addi x1, x0, 5     (x1 = 5)
00A00113  // 0x04: addi x2, x0, 10    (x2 = 10)

// --- TEST 1: JAL - jump forward, save return address ---
00C004EF  // 0x08: jal  x9, +12       (x9 = PC+4 = 0x0C, jump to 0x14)
00100193  // 0x0C: addi x3, x0, 1     (SKIPPED)
00100193  // 0x10: addi x3, x0, 1     (SKIPPED)
00000193  // 0x14: addi x3, x0, 0     (x3 = 0, JAL lands here)

// --- TEST 2: JALR - jump to register+offset, save return address ---
01400213  // 0x18: addi x4, x0, 20    (x4 = 20 = 0x14... need 0x28)
02800213  // 0x1C: addi x4, x0, 40    (x4 = 0x28)
000202E7  // 0x20: jalr x5, x4, 0     (x5 = PC+4 = 0x24, jump to x4+0 = 0x28)
00100313  // 0x24: addi x6, x0, 1     (SKIPPED)
00000313  // 0x28: addi x6, x0, 0     (x6 = 0, JALR lands here)

// --- TEST 3: Function call pattern (JAL to "function", JALR back) ---
010000EF  // 0x2C: jal  x1, +16       (x1 = 0x30, jump to 0x3C = "function")
06300393  // 0x30: addi x7, x0, 99    (x7 = 99, returned here from function)
00000013  // 0x34: addi x0, x0, 0     (NOP - end)
00000013  // 0x38: addi x0, x0, 0     (NOP - end)
01400413  // 0x3C: addi x8, x0, 20    (x8 = 20, "function body")
00008067  // 0x40: jalr x0, x1, 0     (jump back to x1 = 0x30, discard return addr)
